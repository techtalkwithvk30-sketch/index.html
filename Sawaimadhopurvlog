// ── NAVIGATION ──
let currentPage = 'home';
function navigate(page, close=true) {
  document.querySelectorAll('.page-section').forEach(el => el.classList.remove('active'));
  const target = document.getElementById('page-'+page);
  if(target){
    target.classList.add('active');
    currentPage = page;
    window.scrollTo({top:0,behavior:'smooth'});
  }
  // Update nav active
  document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
  const navA = document.querySelector(`.nav-links a[onclick*="${page}"]`);
  if(navA) navA.classList.add('active');
  if(close) closeMobMenu();
  // Lazy render
  if(page==='explore') renderExplore('all');
  if(page==='gallery') renderGallery('all');
  return false;
}

// ── HAMBURGER ──
function toggleMenu(){
  document.getElementById('hamBtn').classList.toggle('open');
  document.getElementById('mobMenu').classList.toggle('open');
}
function closeMobMenu(){
  document.getElementById('hamBtn').classList.remove('open');
  document.getElementById('mobMenu').classList.remove('open');
}

// ── EXPLORE ──
let currentCat = 'all';
function renderExplore(cat){
  currentCat = cat;
  const q = document.getElementById('exploreSearch')?.value?.toLowerCase()||'';
  const filtered = allPlaces.filter(p => {
    const matchCat = cat==='all' || p.tag===cat;
    const matchQ = !q || p.name.toLowerCase().includes(q) || p.desc.toLowerCase().includes(q);
    return matchCat && matchQ;
  });
  const grid = document.getElementById('exploreGrid');
  if(!grid) return;
  grid.innerHTML = filtered.map(p=>`
    <div class="card">
      <div class="card-img" style="font-size:3.5rem;">${p.emoji}</div>
      <div class="card-body">
        <div class="card-tag">${p.label}</div>
        <h3>${p.name}</h3>
        <p>${p.desc}</p>
        <div class="card-meta">
          <span>⭐ ${p.rating}</span>
          <span><b>Best:</b> ${p.season}</span>
          <span>📍 ${p.dist}</span>
        </div>
      </div>
    </div>
  `).join('');
}
function filterExplore(){renderExplore(currentCat);}
function setCategory(btn, cat){
  document.querySelectorAll('.cat-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderExplore(cat);
}

// ── GALLERY ──
function renderGallery(cat){
  const items = cat==='all' ? galleryItems : galleryItems.filter(i=>i.cat===cat);
  const grid = document.getElementById('galleryGrid');
  if(!grid) return;
  grid.innerHTML = items.map(i=>`
    <div class="gal-item" style="min-height:120px;">${i.emoji}</div>
  `).join('');
}
function setGalCat(btn, cat){
  document.querySelectorAll('#page-gallery .cat-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderGallery(cat);
}

// ── TABS ──
function openTab(btn, id){
  const parent = btn.closest('section')||btn.closest('.page-section');
  parent.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  parent.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  btn.classList.add('active');
  const panel = document.getElementById(id);
  if(panel) panel.classList.add('active');
}

// ── FAQ ──
function toggleFaq(el){
  const item = el.closest('.faq-item');
  item.classList.toggle('open');
}

// ── MODALS ──
function openModal(id){
  document.getElementById(id).classList.add('open');
}
function closeModal(id){
  document.getElementById(id).classList.remove('open');
}
document.querySelectorAll('.modal-bg').forEach(bg=>{
  bg.addEventListener('click',e=>{
    if(e.target===bg) bg.classList.remove('open');
  });
});

function openBlogModal(key){
  const b = blogs[key];
  document.getElementById('blogModalContent').innerHTML = `
    <div class="sec-label">${b.cat}</div>
    <h2 style="font-family:'Playfair Display',serif;font-size:1.4rem;margin-bottom:12px;">${b.title}</h2>
    <div class="divider"></div>
    <p style="color:var(--muted2);font-size:.88rem;line-height:1.85;">${b.content}</p>
    <div style="margin-top:24px;">
      <a href="https://youtube.com/@sawaimadhopurvlog" target="_blank" class="btn btn-ghost" style="font-size:.8rem;">Watch Video on YouTube →</a>
    </div>
  `;
  openModal('blogModal');
}

// ── CURSOR ──
const cur = document.getElementById('cur');
const ring = document.getElementById('cur-ring');
document.addEventListener('mousemove', e=>{
  cur.style.transform = `translate(${e.clientX-5}px,${e.clientY-5}px)`;
  ring.style.transform = `translate(${e.clientX-18}px,${e.clientY-18}px)`;
});

// ── PREVENT DEFAULT ON HASH LINKS ──
document.querySelectorAll('a[href="#"]').forEach(a=>{
  a.addEventListener('click',e=>e.preventDefault());
});

// ── INIT ──
navigate('home', false);
</script>
