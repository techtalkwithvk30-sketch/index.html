      display:grid;
      grid-template-columns:1.5fr 1fr 1fr 1fr;
      gap:40px;margin-bottom:56px;
    }
    .footer-brand .logo{margin-bottom:16px;display:block;}
    .footer-brand p{font-size:.83rem;color:var(--muted);line-height:1.7;max-width:260px;}
