<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Sawai Madhopur Vlogs — Rajasthan's Premier Travel Portal</title>
  <meta name="description" content="Explore Sawai Madhopur, Ranthambore National Park, ancient temples, forts, wildlife safaris, food, and hidden gems of Rajasthan. Your ultimate travel guide."/>
  <meta name="keywords" content="Sawai Madhopur Vlogs, Ranthambore vlog, Sawai Madhopur tourism, Rajasthan travel guide, Ranthambore safari, best places in Sawai Madhopur"/>
  <meta property="og:title" content="Sawai Madhopur Vlogs — Rajasthan's Premier Travel Portal"/>
  <meta property="og:description" content="Cinematic travel vlogs and complete tourism guide for Sawai Madhopur and surrounding 100KM."/>
  <meta property="og:type" content="website"/>
  <meta name="robots" content="index, follow"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@300;400;500;600&family=Bebas+Neue&display=swap" rel="stylesheet"/>

  <style>
    :root {
      --gold: #C9A84C;
      --gold-light: #E8C97A;
      --gold-dim: rgba(201,168,76,0.15);
      --dark: #080807;
      --dark2: #0F0E0C;
      --card: #131210;
      --card2: #1A1917;
      --border: rgba(201,168,76,0.12);
      --border-hover: rgba(201,168,76,0.4);
      --text: #F0EAD6;
      --muted: #7A7060;
      --muted2: #A89880;
    }
    *{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;font-size:16px;}
    body{
      background:var(--dark);
      color:var(--text);
      font-family:'DM Sans',sans-serif;
      overflow-x:hidden;
      cursor:none;
    }

    /* ── CURSOR ── */
    #cur{
      width:10px;height:10px;
      background:var(--gold);
      border-radius:50%;
      position:fixed;top:0;left:0;
      pointer-events:none;z-index:9999;
      transition:transform .1s ease;
    }
    #cur-ring{
      width:36px;height:36px;
      border:1px solid var(--gold);
      border-radius:50%;
      position:fixed;top:0;left:0;
      pointer-events:none;z-index:9998;
      opacity:.4;
      transition:transform .3s ease,width .3s,height .3s,opacity .3s;
    }
    body:hover #cur-ring{opacity:.6;}
    a:hover~#cur-ring,.btn:hover~#cur-ring{width:56px;height:56px;}

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar{width:4px;}
    ::-webkit-scrollbar-track{background:var(--dark2);}
    ::-webkit-scrollbar-thumb{background:var(--gold);border-radius:2px;}

    /* ── NAV ── */
    nav{
      position:fixed;top:0;width:100%;z-index:200;
      padding:0 5vw;
      background:linear-gradient(to bottom,rgba(8,8,7,.97) 60%,transparent);
      backdrop-filter:blur(10px);
      border-bottom:1px solid rgba(201,168,76,.06);
      display:flex;align-items:center;justify-content:space-between;
      height:68px;
    }
    .logo{
      font-family:'Playfair Display',serif;
      font-size:1.35rem;
      letter-spacing:.5px;
      color:var(--text);
      text-decoration:none;
      display:flex;align-items:center;gap:8px;
    }
    .logo-icon{
      width:34px;height:34px;
      background:var(--gold);
      border-radius:50%;
      display:flex;align-items:center;justify-content:center;
      font-size:.9rem;
      flex-shrink:0;
    }
    .logo span{color:var(--gold);}
    .nav-links{
      display:flex;gap:28px;list-style:none;
    }
    .nav-links a{
      color:var(--muted2);
      text-decoration:none;
      font-size:.78rem;
      font-weight:500;
      letter-spacing:1.5px;
      text-transform:uppercase;
      transition:color .25s;
      position:relative;
    }
    .nav-links a::after{
      content:'';
      position:absolute;bottom:-4px;left:0;
      width:0;height:1px;
      background:var(--gold);
      transition:width .25s;
    }
    .nav-links a:hover{color:var(--gold);}
    .nav-links a:hover::after{width:100%;}
    .nav-cta{
      background:var(--gold);
      color:#080807;
      padding:10px 22px;
      border-radius:3px;
      font-size:.78rem;
      font-weight:700;
      letter-spacing:1px;
      text-transform:uppercase;
      text-decoration:none;
      transition:background .2s,transform .2s;
    }
    .nav-cta:hover{background:var(--gold-light);transform:translateY(-1px);}

    /* hamburger */
    .ham{display:none;flex-direction:column;gap:5px;cursor:pointer;z-index:300;}
    .ham span{width:26px;height:2px;background:var(--text);transition:.3s;}
    .ham.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
    .ham.open span:nth-child(2){opacity:0;}
    .ham.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}
    .mob-menu{
      display:none;
      position:fixed;top:0;left:0;width:100%;height:100vh;
      background:rgba(8,8,7,.98);
      z-index:250;
      flex-direction:column;
      align-items:center;justify-content:center;
      gap:32px;
    }
    .mob-menu.open{display:flex;}
    .mob-menu a{
      color:var(--text);text-decoration:none;
      font-family:'Playfair Display',serif;
      font-size:2rem;letter-spacing:1px;
      transition:color .2s;
    }
    .mob-menu a:hover{color:var(--gold);}

    /* ── HERO ── */
    .hero{
      height:100vh;min-height:600px;
      position:relative;
      display:flex;align-items:flex-end;
      overflow:hidden;
    }
    .hero-bg{
      position:absolute;inset:0;
      background:
        radial-gradient(ellipse at 20% 50%,rgba(201,168,76,.07) 0%,transparent 60%),
        radial-gradient(ellipse at 80% 20%,rgba(201,168,76,.04) 0%,transparent 50%),
        linear-gradient(160deg,#0F0D09 0%,#080807 60%,#0C0A06 100%);
    }
    .hero-grid{
      position:absolute;inset:0;
      background-image:
        linear-gradient(rgba(201,168,76,.04) 1px,transparent 1px),
        linear-gradient(90deg,rgba(201,168,76,.04) 1px,transparent 1px);
      background-size:60px 60px;
      mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black 30%,transparent 100%);
    }
    .hero-marquee{
      position:absolute;top:50%;left:0;
      transform:translateY(-50%);
      width:100%;overflow:hidden;
      pointer-events:none;
    }
    .hero-marquee-inner{
      display:flex;
      animation:marquee 30s linear infinite;
      white-space:nowrap;
    }
    .hero-marquee-inner span{
      font-family:'Bebas Neue',sans-serif;
      font-size:clamp(100px,18vw,240px);
      color:rgba(201,168,76,.03);
      letter-spacing:4px;
      margin-right:60px;
      line-height:1;
    }
    @keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}

    .hero-content{
      position:relative;z-index:10;
      padding:0 5vw 10vh;
      max-width:900px;
    }
    .hero-pill{
      display:inline-flex;align-items:center;gap:8px;
      border:1px solid var(--border-hover);
      padding:6px 16px;border-radius:20px;
      font-size:.72rem;letter-spacing:2px;
      text-transform:uppercase;color:var(--gold);
      margin-bottom:28px;
      animation:fadeUp .8s ease both;
    }
    .hero-pill-dot{
      width:6px;height:6px;
      background:var(--gold);border-radius:50%;
      animation:pulse 2s ease infinite;
    }
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
    .hero h1{
      font-family:'Playfair Display',serif;
      font-size:clamp(44px,7vw,92px);
      line-height:1.0;
      letter-spacing:-1px;
      animation:fadeUp .9s .1s ease both;
    }
    .hero h1 em{
      font-style:italic;color:var(--gold);
    }
    .hero-sub{
      margin-top:20px;
      font-size:1rem;
      color:var(--muted2);
      max-width:520px;
      line-height:1.75;
      font-weight:300;
      animation:fadeUp 1s .2s ease both;
    }
    .hero-actions{
      margin-top:36px;
      display:flex;gap:14px;flex-wrap:wrap;
      animation:fadeUp 1.1s .3s ease both;
    }
    .btn{
      display:inline-flex;align-items:center;gap:8px;
      padding:14px 30px;border-radius:3px;
      font-size:.85rem;font-weight:600;
      letter-spacing:.5px;text-decoration:none;
      transition:transform .2s,box-shadow .2s,background .2s;
      cursor:pointer;border:none;outline:none;
    }
    .btn-gold{
      background:var(--gold);color:#080807;
    }
    .btn-gold:hover{
      background:var(--gold-light);
      transform:translateY(-2px);
      box-shadow:0 10px 30px rgba(201,168,76,.35);
    }
    .btn-ghost{
      background:transparent;
      border:1px solid var(--border-hover);
      color:var(--text);
    }
    .btn-ghost:hover{
      background:var(--gold-dim);
      border-color:var(--gold);
      transform:translateY(-2px);
    }
    .hero-stats{
      margin-top:60px;
      display:flex;gap:48px;flex-wrap:wrap;
      animation:fadeUp 1.2s .4s ease both;
    }
    .stat-num{
      font-family:'Playfair Display',serif;
      font-size:2.4rem;color:var(--gold);line-height:1;
    }
    .stat-lbl{
      font-size:.7rem;letter-spacing:2px;
      text-transform:uppercase;color:var(--muted);
      margin-top:4px;
    }

    /* scroll indicator */
    .scroll-ind{
      position:absolute;bottom:36px;right:5vw;
      display:flex;flex-direction:column;align-items:center;gap:8px;
      z-index:10;animation:fadeUp 1.4s .6s ease both;
    }
    .scroll-ind span{
      font-size:.65rem;letter-spacing:3px;
      text-transform:uppercase;color:var(--muted);
      writing-mode:vertical-lr;
    }
    .scroll-line{
      width:1px;height:50px;
      background:linear-gradient(to bottom,var(--gold),transparent);
      animation:scrollLine 2s ease infinite;
    }
    @keyframes scrollLine{0%{transform:scaleY(0);transform-origin:top}50%{transform:scaleY(1);transform-origin:top}51%{transform:scaleY(1);transform-origin:bottom}100%{transform:scaleY(0);transform-origin:bottom}}

    @keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}

    /* ── SECTION BASE ── */
    section{padding:100px 5vw;}
    .sec-label{
      font-size:.68rem;letter-spacing:4px;
      text-transform:uppercase;color:var(--gold);
      font-weight:600;margin-bottom:10px;
      display:flex;align-items:center;gap:10px;
    }
    .sec-label::before{
      content:'';width:24px;height:1px;background:var(--gold);
    }
    .sec-title{
      font-family:'Playfair Display',serif;
      font-size:clamp(32px,4.5vw,56px);
      letter-spacing:-1px;line-height:1.1;
      margin-bottom:10px;
    }
    .sec-title em{font-style:italic;color:var(--gold);}
    .sec-sub{
      color:var(--muted2);font-size:.9rem;
      max-width:500px;line-height:1.7;
      font-weight:300;margin-bottom:56px;
    }
    .sec-head{margin-bottom:56px;}

    /* divider */
    .divider{
      width:60px;height:1px;
      background:linear-gradient(to right,var(--gold),transparent);
      margin:16px 0 24px;
    }

    /* ── FEATURED PLACES ── */
    .places-grid{
      display:grid;
      grid-template-columns:repeat(auto-fill,minmax(300px,1fr));
      gap:1px;
      border:1px solid var(--border);
    }
    .place-card{
      position:relative;overflow:hidden;
      aspect-ratio:3/4;
      background:var(--card);
      cursor:pointer;
    }
    .place-card-img{
      width:100%;height:100%;
      object-fit:cover;
      transition:transform .6s ease;
      background:linear-gradient(135deg,var(--card2),var(--card));
      display:flex;align-items:center;justify-content:center;
      font-size:5rem;
    }
    .place-card:hover .place-card-img{transform:scale(1.06);}
    .place-overlay{
      position:absolute;inset:0;
      background:linear-gradient(to top,rgba(8,8,7,.95) 30%,transparent 70%);
    }
    .place-card-body{
      position:absolute;bottom:0;left:0;right:0;
      padding:28px 24px;
    }
    .place-tag{
      display:inline-block;
      background:var(--gold);color:#080807;
      font-size:.62rem;letter-spacing:2px;
      text-transform:uppercase;font-weight:700;
      padding:4px 10px;border-radius:2px;
      margin-bottom:10px;
    }
    .place-card-body h3{
      font-family:'Playfair Display',serif;
      font-size:1.3rem;line-height:1.2;
      margin-bottom:8px;
    }
    .place-card-body p{
      font-size:.8rem;color:var(--muted2);
      line-height:1.6;
      max-height:0;overflow:hidden;
      transition:max-height .4s ease,opacity .4s;
      opacity:0;
    }
    .place-card:hover .place-card-body p{max-height:80px;opacity:1;}
    .place-card-body .arrow{
      display:inline-flex;align-items:center;gap:6px;
      color:var(--gold);font-size:.75rem;
      letter-spacing:1px;text-transform:uppercase;
      margin-top:12px;
      opacity:0;transform:translateX(-8px);
      transition:opacity .3s .1s,transform .3s .1s;
    }
    .place-card:hover .arrow{opacity:1;transform:translateX(0);}

    /* ── CATEGORIES STRIP ── */
    .cat-strip{
      display:flex;gap:12px;flex-wrap:wrap;
      margin-bottom:40px;
    }
    .cat-btn{
      padding:9px 20px;
      border:1px solid var(--border);
      border-radius:30px;
      font-size:.75rem;letter-spacing:1px;
      text-transform:uppercase;color:var(--muted2);
      cursor:pointer;background:transparent;
      transition:.25s;
      font-family:'DM Sans',sans-serif;
    }
    .cat-btn:hover,.cat-btn.active{
      background:var(--gold);color:#080807;
      border-color:var(--gold);font-weight:600;
    }

    /* ── WILDLIFE ── */
    .wildlife-hero{
      background:
        radial-gradient(ellipse at 30% 60%,rgba(201,168,76,.08) 0%,transparent 60%),
        var(--dark2);
      border:1px solid var(--border);
      border-radius:8px;
      padding:60px 5%;
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:60px;
      align-items:center;
      margin-bottom:60px;
    }
    .wildlife-hero-emoji{
      font-size:8rem;text-align:center;
      animation:float 6s ease-in-out infinite;
    }
    @keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-16px)}}
    .wildlife-hero h2{
      font-family:'Playfair Display',serif;
      font-size:clamp(28px,4vw,50px);
      line-height:1.1;margin-bottom:16px;
    }
    .wildlife-hero h2 em{font-style:italic;color:var(--gold);}
    .wildlife-hero p{color:var(--muted2);line-height:1.75;font-size:.92rem;}
    .info-chips{
      display:flex;gap:10px;flex-wrap:wrap;margin-top:20px;
    }
    .chip{
      padding:6px 14px;
      border:1px solid var(--border-hover);
      border-radius:20px;
      font-size:.72rem;letter-spacing:1px;
      color:var(--gold);text-transform:uppercase;
    }

    /* ── CARDS GRID (generic) ── */
    .cards-grid{
      display:grid;
      grid-template-columns:repeat(auto-fill,minmax(280px,1fr));
      gap:20px;
    }
    .card{
      background:var(--card);
      border:1px solid var(--border);
      border-radius:6px;
      overflow:hidden;
      transition:border-color .3s,transform .3s,box-shadow .3s;
    }
    .card:hover{
      border-color:var(--border-hover);
      transform:translateY(-5px);
      box-shadow:0 20px 50px rgba(0,0,0,.5);
    }
    .card-img{
      aspect-ratio:16/9;
      background:var(--card2);
      display:flex;align-items:center;justify-content:center;
      font-size:3.5rem;
      transition:transform .5s;
      overflow:hidden;
    }
    .card:hover .card-img{transform:scale(1.05);}
    .card-body{padding:20px;}
    .card-tag{
      font-size:.62rem;letter-spacing:2px;
      text-transform:uppercase;color:var(--gold);
      font-weight:600;margin-bottom:8px;
    }
    .card-body h3{
      font-family:'Playfair Display',serif;
      font-size:1.1rem;margin-bottom:8px;line-height:1.3;
    }
    .card-body p{
      font-size:.82rem;color:var(--muted2);
      line-height:1.65;margin-bottom:14px;
    }
    .card-meta{
      display:flex;gap:16px;flex-wrap:wrap;
    }
    .card-meta span{
      font-size:.7rem;color:var(--muted);
      letter-spacing:.5px;
    }
    .card-meta span b{color:var(--gold);}

    /* ── BLOG ── */
    .blog-grid{
      display:grid;
      grid-template-columns:1.4fr 1fr 1fr;
      gap:20px;
    }
    .blog-card-big{
      grid-row:span 2;
    }
    .blog-card{
      background:var(--card);
      border:1px solid var(--border);
      border-radius:6px;overflow:hidden;
      transition:.3s;cursor:pointer;
    }
    .blog-card:hover{border-color:var(--border-hover);transform:translateY(-4px);}
    .blog-card-big .blog-img{aspect-ratio:4/5;}
    .blog-img{
      aspect-ratio:16/9;
      background:var(--card2);
      display:flex;align-items:center;justify-content:center;
      font-size:3rem;overflow:hidden;
    }
    .blog-card-big .blog-img{font-size:5rem;}
    .blog-body{padding:20px;}
    .blog-cat{
      font-size:.62rem;letter-spacing:2px;
      text-transform:uppercase;color:var(--gold);
      font-weight:600;margin-bottom:8px;
    }
    .blog-body h3{
      font-family:'Playfair Display',serif;
      font-size:1.1rem;line-height:1.3;margin-bottom:10px;
    }
    .blog-card-big .blog-body h3{font-size:1.5rem;}
    .blog-meta{
      display:flex;gap:16px;
      font-size:.7rem;color:var(--muted);
    }

    /* ── GALLERY ── */
    .gallery-masonry{
      columns:4 240px;
      gap:10px;
    }
    .gal-item{
      break-inside:avoid;
      margin-bottom:10px;
      background:var(--card2);
      border-radius:4px;
      display:flex;align-items:center;justify-content:center;
      font-size:2.5rem;
      border:1px solid var(--border);
      overflow:hidden;
      cursor:pointer;
      transition:border-color .3s,transform .3s;
    }
    .gal-item:hover{border-color:var(--border-hover);transform:scale(1.02);}
    .gal-item:nth-child(odd){aspect-ratio:4/5;}
    .gal-item:nth-child(even){aspect-ratio:4/3;}
    .gal-item:nth-child(3n){aspect-ratio:1/1;}

    /* ── VIDEO SECTION ── */
    .video-row{
      display:grid;
      grid-template-columns:1fr 1fr 1fr;
      gap:20px;
    }
    .vcard{
      background:var(--card);
      border:1px solid var(--border);
      border-radius:6px;overflow:hidden;
      transition:.3s;cursor:pointer;
    }
    .vcard:hover{border-color:var(--border-hover);transform:translateY(-4px);}
    .vcard-thumb{
      aspect-ratio:16/9;
      background:var(--card2);
      display:flex;align-items:center;justify-content:center;
      position:relative;font-size:3rem;
      overflow:hidden;
    }
    .play-overlay{
      position:absolute;inset:0;
      display:flex;align-items:center;justify-content:center;
      background:rgba(0,0,0,.4);
      opacity:0;transition:.3s;
    }
    .play-icon{
      width:54px;height:54px;
      background:var(--gold);border-radius:50%;
      display:flex;align-items:center;justify-content:center;
    }
    .play-icon svg{width:20px;fill:#080807;margin-left:3px;}
    .vcard:hover .play-overlay{opacity:1;}
    .vcard-body{padding:16px;}
    .vcard-body h4{
      font-family:'Playfair Display',serif;
      font-size:1rem;margin-bottom:6px;line-height:1.4;
    }
    .vcard-body p{font-size:.78rem;color:var(--muted2);}

    /* ── FOOD ── */
    .food-grid{
      display:grid;
      grid-template-columns:repeat(auto-fill,minmax(240px,1fr));
      gap:16px;
    }
    .food-card{
      background:var(--card);
      border:1px solid var(--border);
      border-radius:6px;overflow:hidden;
      transition:.3s;
    }
    .food-card:hover{border-color:var(--border-hover);transform:translateY(-4px);}
    .food-img{
      aspect-ratio:4/3;
      background:var(--card2);
      display:flex;align-items:center;justify-content:center;
      font-size:3.5rem;
    }
    .food-body{padding:16px;}
    .price-tag{
      display:inline-block;
      background:rgba(201,168,76,.15);
      color:var(--gold);
      font-size:.7rem;letter-spacing:1px;
      padding:3px 10px;border-radius:12px;
      font-weight:600;margin-bottom:8px;
    }
    .food-body h4{
      font-family:'Playfair Display',serif;
      font-size:1rem;margin-bottom:6px;
    }
    .food-body p{font-size:.78rem;color:var(--muted2);line-height:1.6;}

    /* ── MAP / INFO BOX ── */
    .info-box{
      background:var(--card);
      border:1px solid var(--border);
      border-radius:6px;padding:32px;
      margin-bottom:20px;
    }
    .info-box h3{
      font-family:'Playfair Display',serif;
      font-size:1.2rem;margin-bottom:16px;
      display:flex;align-items:center;gap:10px;
    }
    .info-row{
      display:flex;gap:10px;align-items:flex-start;
      padding:12px 0;border-bottom:1px solid var(--border);
      font-size:.85rem;
    }
    .info-row:last-child{border-bottom:none;}
    .info-row .key{color:var(--muted);min-width:140px;flex-shrink:0;}
