      display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));
      gap:14px;margin-top:32px;
    }
    .hl-box{
      background:var(--gold-dim);
      border:1px solid var(--border-hover);
      border-radius:4px;padding:20px;
    }
    .hl-box h4{
      font-size:.72rem;letter-spacing:2px;
      text-transform:uppercase;color:var(--gold);
      margin-bottom:8px;
    }
    .hl-box p{font-size:.85rem;color:var(--text);line-height:1.6;}

    /* ── PAGE SECTIONS ── */
    .page-section{display:none;}
    .page-section.active{display:block;}

    /* ── RESPONSIVE ── */
    @media(max-width:1024px){
      .blog-grid{grid-template-columns:1fr 1fr;}
      .blog-card-big{grid-column:span 2;grid-row:auto;}
      .footer-grid{grid-template-columns:1fr 1fr;}
      .video-row{grid-template-columns:1fr 1fr;}
    }
    @media(max-width:768px){
      nav{padding:0 20px;}
      section{padding:70px 20px;}
      .nav-links{display:none;}
      .nav-cta{display:none;}
      .ham{display:flex;}
      .hero-content{padding:0 20px 12vh;}
      .hero-stats{gap:28px;}
      .blog-grid{grid-template-columns:1fr;}
      .blog-card-big{grid-column:auto;}
      .contact-wrap{grid-template-columns:1fr;}
      .footer-grid{grid-template-columns:1fr;}
      .places-grid{grid-template-columns:1fr 1fr;}
      .wildlife-hero{grid-template-columns:1fr;}
      .video-row{grid-template-columns:1fr;}
      .social-links-wrap{grid-template-columns:1fr;}
      .nl-form{flex-direction:column;}
    }
    @media(max-width:480px){
      .places-grid{grid-template-columns:1fr;}
      .gallery-masonry{columns:2 120px;}
    }

    /* ── TABS ── */
    .tabs{display:flex;gap:4px;margin-bottom:32px;border-bottom:1px solid var(--border);}
    .tab{
      padding:12px 20px;cursor:pointer;
      font-size:.78rem;letter-spacing:1.5px;
      text-transform:uppercase;color:var(--muted);
      border-bottom:2px solid transparent;
      transition:.2s;margin-bottom:-1px;
      background:none;border-left:none;border-right:none;border-top:none;
      font-family:'DM Sans',sans-serif;
    }
    .tab.active{color:var(--gold);border-bottom-color:var(--gold);}
    .tab-panel{display:none;}
    .tab-panel.active{display:block;}

    /* ── BADGE ── */
    .badge{
      display:inline-flex;align-items:center;gap:4px;
      padding:3px 10px;border-radius:12px;
      font-size:.62rem;letter-spacing:1.5px;
      text-transform:uppercase;font-weight:600;
      background:var(--gold-dim);color:var(--gold);
      border:1px solid rgba(201,168,76,.25);
    }

    /* loading animation */
    .shimmer{
      background:linear-gradient(90deg,var(--card) 25%,var(--card2) 50%,var(--card) 75%);
      background-size:200% 100%;
      animation:shimmer 1.5s infinite;
    }
    @keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}

    /* ── ACTIVE NAV ── */
    .nav-links a.active{color:var(--gold);}
  </style>
</head>
