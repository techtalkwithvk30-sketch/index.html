        radial-gradient(ellipse at 50% 100%,rgba(201,168,76,.12) 0%,transparent 70%),
        var(--card);
      border:1px solid var(--border);
      border-radius:8px;
      padding:72px 5vw;
      text-align:center;
    }
    .newsletter h2{
